      // ---------- กรอง + แบ่งหน้า (กริด) ----------
      function buildFilterOptions(){
        DEPT_SET={}; for(var i=0;i<LOOKUPS.depts.length;i++) DEPT_SET[String(LOOKUPS.depts[i])]=1;
        CAT_SET={};  for(var j=0;j<LOOKUPS.mainCats.length;j++) CAT_SET[String(LOOKUPS.mainCats[j])]=1;
        var set={}; GRID_SUBCATS=[];
        for(var k=0;k<MATERIALS.length;k++){ var s=String(MATERIALS[k].subCat||'').trim(); if(s && !set[s]){ set[s]=1; GRID_SUBCATS.push(s); } }
        GRID_SUBCATS.sort(function(a,b){ return a.localeCompare(b,'th'); });
        SUBCAT_SET=set;
      }
      // ตรงเป๊ะถ้าค่าเป็นตัวเลือกจริง, ไม่งั้น substring (เหมือนตัวกรอง ERP)
      function matchOne(val, target, knownSet){
        if(!val) return true;
        if(knownSet[val]) return String(target||'')===val;
        return String(target||'').toLowerCase().indexOf(val.toLowerCase())!==-1;
      }
      function applyFilters(){
        var q=(document.getElementById('search').value||'').trim().toLowerCase();
        var dp=(document.getElementById('filterDept').value||'').trim();
        var mc=(document.getElementById('filterCat').value||'').trim();
        var sc=(document.getElementById('filterSubCat').value||'').trim();
        document.getElementById('searchClear').classList.toggle('show', q.length>0);
        var trs=document.getElementById('tbody').children;
        GRID_MATCHED=[];
        for(var i=0;i<trs.length;i++){
          var rn=Number(trs[i].getAttribute('data-row')), m=BY_ROW[rn], ok;
          if(newRows[rn]){ ok=true; }   // รายการที่เพิ่งเพิ่ม แสดงเสมอ
          else {
            var hay=((m.code||'')+' '+(m.name1||'')+' '+(m.name2||'')+' '+(m.subCat||'')+' '+(m.mainCat||'')+' '+(m.mainDept||'')+' '+(m.subDept||'')).toLowerCase();
            var okDept = dp==='' || (DEPT_SET[dp] ? (String(m.mainDept||'')===dp || splitMulti(m.subDept).indexOf(dp)!==-1)
                                                  : ((String(m.mainDept||'')+' '+String(m.subDept||'')).toLowerCase().indexOf(dp.toLowerCase())!==-1));
            ok = (q===''||hay.indexOf(q)!==-1) && okDept && matchOne(mc, m.mainCat, CAT_SET) && matchOne(sc, m.subCat, SUBCAT_SET);
          }
          if(ok) GRID_MATCHED.push(trs[i]); else trs[i].classList.add('hide');
        }
        gridPage=1;
        renderGridPage();
      }
      function renderGridPage(){
        var total=GRID_MATCHED.length, all=(GRID_PAGE_SIZE==='all');
        var size=all?(total||1):GRID_PAGE_SIZE, pages=all?1:Math.max(1,Math.ceil(total/size));
        if(gridPage>pages)gridPage=pages; if(gridPage<1)gridPage=1;
        var start=all?0:(gridPage-1)*size, end=all?total:Math.min(start+size,total);
        for(var i=0;i<GRID_MATCHED.length;i++){ GRID_MATCHED[i].classList.toggle('hide', !(i>=start && i<end)); }
        var cnt=document.getElementById('count'), tStr=total.toLocaleString();
        cnt.textContent = (all||total<=size) ? (tStr+' รายการ') : ('แสดง '+(start+1)+'–'+end+' จาก '+tStr+' รายการ');
        var pager=document.getElementById('gridPager');
        if(!all && total>size){
          pager.classList.remove('hide');
          document.getElementById('gridPageInfo').textContent='หน้า '+gridPage+'/'+pages;
          document.getElementById('gridPrev').disabled=(gridPage<=1);
          document.getElementById('gridNext').disabled=(gridPage>=pages);
        } else pager.classList.add('hide');
      }
      function gridGoPage(d){ gridPage+=d; renderGridPage(); var w=document.querySelector('.table-wrap'); if(w) w.scrollTop=0; }

      // ---------- มุมมอง ยุบ/กลาง ----------
      function applyViewMode(){
