      .en-note-foot{font-size:11px;color:var(--muted);margin-top:3px;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
      .en-status{display:inline-block;font-size:11px;padding:1px 8px;border-radius:999px;background:#fde68a;color:#92500a}
