      // ---------- refresh / paint ----------
      // วาดกริดจาก data ที่มีอยู่ (ไม่เรียก server) — keepFilters=true จะคงค่ากรอง/ค้นหาไว้
      function paintGrid(data, keepFilters){
        var fd,fc,fs,sv;
        if(keepFilters){ fd=document.getElementById('filterDept').value; fc=document.getElementById('filterCat').value;
          fs=document.getElementById('filterSubCat').value; sv=document.getElementById('search').value; }
        MATERIALS=data||[]; BY_ROW={}; dirty={}; pending={}; newRows={};
        var rows=new Array(MATERIALS.length);
        for(var i=0;i<MATERIALS.length;i++){ var m=MATERIALS[i]; BY_ROW[m.row]=m; rows[i]=rowHtml(m); }
        document.getElementById('tbody').innerHTML=rows.join('');
        document.getElementById('loading').classList.add('hide');
        document.getElementById('grid').classList.remove('hide');
        buildFilterOptions();
        if(keepFilters){ document.getElementById('filterDept').value=fd; document.getElementById('filterCat').value=fc;
          document.getElementById('filterSubCat').value=fs; document.getElementById('search').value=sv; }
        else { document.getElementById('search').value=''; }
        applyFilters(); updateStatus();
      }
      function reloadGrid(okMsg, btn, keepFilters){
        if(btn) btn.classList.add('spinning');
        google.script.run
          .withSuccessHandler(function(data){
            SHEET_DATA[CURRENT_SHEET]=data||[];
            paintGrid(SHEET_DATA[CURRENT_SHEET], keepFilters);
            if(btn) btn.classList.remove('spinning');
            if(okMsg) showMsg('ok', okMsg);
          })
          .withFailureHandler(function(err){ if(btn) btn.classList.remove('spinning'); showMsg('err','โหลดไม่สำเร็จ: '+(err&&err.message?err.message:err)); })
          .getMaterials(CURRENT_SHEET);
      }
      function refreshData(){ reloadGrid('รีเฟรชข้อมูลแล้ว', document.getElementById('refreshBtn'), true); }

      // ---------- เพิ่ม/ลบ แถว ----------
      function deleteRowFlow(row){
        if(!confirm('ลบรายการนี้ออกจาก database?')) return;
        google.script.run
          .withSuccessHandler(function(){ reloadGrid('ลบรายการแล้ว', null, true); })
          .withFailureHandler(function(err){ showMsg('err','ลบไม่สำเร็จ: '+(err&&err.message?err.message:err)); })
          .deleteRow(row, CURRENT_SHEET);
      }

      // ---------- ปรับความกว้างคอลัมน์ ----------
      function applyColStyle(){
        var css='';
        for(var c=1;c<=COL_COUNT;c++){ var w=COLW[c]; if(!w)continue; css+='#grid tr>th:nth-child('+c+'),#grid tr>td:nth-child('+c+'){width:'+w+'px;min-width:'+w+'px;max-width:'+w+'px}'; }
        document.getElementById('colStyle').textContent=css;
      }
      var _colPending=false;
      function applyColStyleThrottled(){ if(_colPending)return; _colPending=true; requestAnimationFrame(function(){ _colPending=false; applyColStyle(); }); }
      function setupResizers(){
        var ths=document.querySelectorAll('#grid thead th');
        for(var i=0;i<ths.length;i++){ COL_NAMES[i+1]=((ths[i].childNodes[0]&&ths[i].childNodes[0].nodeValue)||ths[i].textContent||'').trim(); var rz=document.createElement('span'); rz.className='col-resizer'; rz.setAttribute('data-col',i+1); ths[i].appendChild(rz); }
        var col=null, sx=0, sw=0;
        document.querySelector('#grid thead').addEventListener('pointerdown', function(e){ var rz=e.target.closest('.col-resizer'); if(!rz)return; e.preventDefault(); col=Number(rz.getAttribute('data-col')); sx=e.clientX; sw=COLW[col]||rz.parentNode.offsetWidth; document.body.classList.add('col-resizing-active'); });
        document.addEventListener('pointermove', function(e){ if(col==null)return; COLW[col]=Math.max(40,Math.round(sw+(e.clientX-sx))); applyColStyleThrottled(); });
        function end(){ if(col!=null){ col=null; document.body.classList.remove('col-resizing-active'); } }
        document.addEventListener('pointerup', end); document.addEventListener('pointercancel', end);
      }
      function openSizePanel(c){
        spCol=c; var ths=document.querySelectorAll('#grid thead th');
        for(var i=0;i<ths.length;i++) ths[i].classList.toggle('col-selected',(i+1)===c);
        document.getElementById('spName').textContent=COL_NAMES[c]||('คอลัมน์ '+c);
        var w=COLW[c]||100; document.getElementById('spRange').value=w; document.getElementById('spVal').textContent=w+' px';
        document.getElementById('sizePanel').classList.remove('hide');
      }
      function setColW(c,w){ if(c==null)return; w=Math.max(40,Math.min(600,w)); COLW[c]=w; applyColStyleThrottled(); document.getElementById('spVal').textContent=w+' px'; }
      function closeSizePanel(){ document.getElementById('sizePanel').classList.add('hide'); var s=document.querySelectorAll('#grid thead th.col-selected'); for(var i=0;i<s.length;i++) s[i].classList.remove('col-selected'); spCol=null; }
      function exitResizeMode(){ document.getElementById('grid').classList.remove('selecting'); document.getElementById('resizeToggle').classList.remove('active'); closeSizePanel(); }

      // ---------- สีแผนก ----------
      function applyDeptColorCss(){
        var css='';
        for(var d in DEPT_COLORS){
          var c=DEPT_COLORS[d]; if(!c) continue;
          var sel='[data-dept="'+String(d).replace(/"/g,'\\"')+'"]';
          css+='.chip'+sel+'{background:'+c+';color:#1f2937}';
        }
        document.getElementById('deptColorCss').textContent=css;
      }
      function openDeptColorPanel(){
        var list=document.getElementById('dcpList'), depts=LOOKUPS.depts||[], h='';
        for(var i=0;i<depts.length;i++){ var d=depts[i], c=DEPT_COLORS[d]||'#eef2ff';
          h+='<div class="dcp-row"><span class="dcp-chip" data-dept="'+esc(d)+'" style="background:'+esc(c)+'">'+esc(d)+'</span>'
            +'<span class="dcp-name">'+esc(d)+'</span>'
            +'<input type="color" data-dept="'+esc(d)+'" value="'+esc(toHex_(c))+'"></div>';
        }
        list.innerHTML=h;
        document.getElementById('deptColorPanel').classList.remove('hide');
      }
      function closeDeptColorPanel(){ document.getElementById('deptColorPanel').classList.add('hide'); }
      var _deptSaveTimer=null;
      function onDcpColorInput(e){
        var inp=e.target; if(inp.type!=='color') return;
        var d=inp.getAttribute('data-dept'); DEPT_COLORS[d]=inp.value;
        var chip=document.querySelector('.dcp-chip[data-dept="'+cssEsc_(d)+'"]'); if(chip) chip.style.background=inp.value;
        applyDeptColorCss();
        clearTimeout(_deptSaveTimer); _deptSaveTimer=setTimeout(saveDeptColors,400);
      }
      function resetDeptColors(){
        DEPT_COLORS={}; for(var k in DEFAULT_DEPT_COLORS) DEPT_COLORS[k]=DEFAULT_DEPT_COLORS[k];
        applyDeptColorCss(); openDeptColorPanel(); saveDeptColors();
      }
      function saveDeptColors(){
        google.script.run.withSuccessHandler(function(){}).withFailureHandler(function(err){ showMsg('err','บันทึกสีไม่สำเร็จ: '+(err&&err.message?err.message:err)); }).setDeptColors(JSON.stringify(DEPT_COLORS));
      }
      function toHex_(c){ c=String(c||'').trim(); return /^#[0-9a-fA-F]{6}$/.test(c)?c:'#eef2ff'; }
      function cssEsc_(s){ return String(s).replace(/"/g,'\\"'); }

      // ---------- utils ----------
      function showMsg(type,text){ var m=document.getElementById('msg'); m.className='msg show '+type; m.textContent=text; if(type==='ok') setTimeout(function(){ m.className='msg'; },5000); }
      function esc(s){ return String(s===null||s===undefined?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    </script>
  </body>
</html>
