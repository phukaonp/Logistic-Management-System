        btn.innerHTML = collapsed?ICON.rows:ICON.columns;
        btn.title = collapsed?'มุมมอง: ยุบ — กดเพื่อแสดงแยกคอลัมน์':'มุมมอง: กลาง — กดเพื่อยุบรวม';
