      // ---------- choice popup ----------
      function openChoicePopup(cell){
        var field=cell.getAttribute('data-field'), row=Number(cell.getAttribute('data-crow')), multi=CHOICE_MULTI[field];
        var opts=LOOKUPS[CHOICE_SRC[field]]||[];
        var cur = multi ? splitMulti(BY_ROW[row][field]) : [ (BY_ROW[row][field]!=null?String(BY_ROW[row][field]).trim():'') ];
        var isDept=(CHOICE_SRC[field]==='depts');
        function dot(name){ if(!isDept) return ''; var c=DEPT_COLORS[name]; return '<span class="dept-dot"'+(c?' style="background:'+c+'"':'')+'></span>'; }
        var html='';
        if(multi){
          for(var i=0;i<opts.length;i++){ var d=opts[i]; html+='<label><input type="checkbox" value="'+esc(d)+'"'+(cur.indexOf(d)!==-1?' checked':'')+'>'+dot(d)+esc(d)+'</label>'; }
        } else {
          html+='<div class="opt'+(cur[0]===''?' sel':'')+'" data-v="">— (ว่าง) —</div>';
          for(var j=0;j<opts.length;j++){ var o=opts[j]; html+='<div class="opt'+(cur[0]===o?' sel':'')+'" data-v="'+esc(o)+'">'+dot(o)+esc(o)+'</div>'; }
        }
        var pop=document.getElementById('choicePopup');
        pop.className='choice-popup '+(multi?'multi':'single');
        pop.innerHTML=html; pop._cell=cell; pop._field=field; pop._row=row; pop._multi=multi;
        pop.classList.remove('hide');
        var r=cell.getBoundingClientRect(), pw=Math.max(r.width,210);
        pop.style.minWidth=pw+'px';
        pop.style.left=Math.max(8, Math.min(r.left, window.innerWidth-pw-8))+'px';
        if(r.bottom+260>window.innerHeight){ pop.style.top=''; pop.style.bottom=(window.innerHeight-r.top)+'px'; }
        else { pop.style.bottom=''; pop.style.top=r.bottom+'px'; }
      }
      function onChoiceClick(e){
        e.stopPropagation();
        var pop=document.getElementById('choicePopup');
        if(pop._multi) return;
        var opt=e.target.closest('.opt'); if(!opt) return;
        var row=pop._row, field=pop._field, val=opt.getAttribute('data-v');
        BY_ROW[row][field]=val;
        pop._cell.querySelector('.choice-display').innerHTML=choiceChips(field,val);
        markDirty(row); closeChoicePopup(); saveRow(row);
      }
      var _choiceSaveTimer=null;
      function onChoiceChange(){
        var pop=document.getElementById('choicePopup');
        if(!pop._multi) return;
        var row=pop._row, field=pop._field;
        var sel=[], boxes=pop.querySelectorAll('input[type=checkbox]');
        for(var i=0;i<boxes.length;i++){ if(boxes[i].checked) sel.push(boxes[i].value); }
        BY_ROW[row][field]=sel.join(', ');
        pop._cell.querySelector('.choice-display').innerHTML=choiceChips(field,BY_ROW[row][field]);
        markDirty(row);
        // บันทึกอัตโนมัติหลังหยุดติ๊ก (ไม่ต้องรอปิด popup)
        clearTimeout(_choiceSaveTimer);
        _choiceSaveTimer=setTimeout(function(){ if(dirty[row]) saveRow(row); }, 500);
      }
      function closeChoicePopup(){
        var pop=document.getElementById('choicePopup');
        if(pop.classList.contains('hide')) return;
        var row=pop._row;
        pop.classList.add('hide');
        if(pop._multi && row && dirty[row]) saveRow(row);
      }
      function removeChoice(cell, val){
        var field=cell.getAttribute('data-field'), row=Number(cell.getAttribute('data-crow'));
        BY_ROW[row][field]=splitMulti(BY_ROW[row][field]).filter(function(d){return d!==val;}).join(', ');
        cell.querySelector('.choice-display').innerHTML=choiceChips(field,BY_ROW[row][field]);
        markDirty(row); saveRow(row);
      }

      // ---------- รูปภาพ ----------
      var pendingRow=null;
      function pickImage(row){ pendingRow=row; var inp=document.getElementById('imgFile'); inp.value=''; inp.click(); }
      function onImgFile(){
        var f=this.files&&this.files[0]; this.value='';
        if(!f||pendingRow==null){ pendingRow=null; return; }
        var row=pendingRow; pendingRow=null;
        var td=document.querySelector('td.img-cell[data-imgrow="'+row+'"]'), disp=td?td.querySelector('.img-display'):null;
        if(disp) disp.innerHTML='<span class="img-spin"></span><span class="img-uptxt">อัปโหลด…</span>';
        function restore(msg){ if(disp) disp.innerHTML=imgInner(BY_ROW[row].image); if(msg) showMsg('err',msg); }
        var reader=new FileReader();
        reader.onload=function(){
          try{
            var base64=String(reader.result).split(',')[1];
            if(!base64){ restore('❌ อ่านไฟล์ไม่สำเร็จ'); return; }
            var mime=f.type||'image/jpeg';
            google.script.run
              .withSuccessHandler(function(res){ BY_ROW[row].image=res.url; var t2=document.querySelector('td.img-cell[data-imgrow="'+row+'"]'); if(t2) t2.querySelector('.img-display').innerHTML=imgInner(res.url); showMsg('ok','✅ อัปโหลดรูปแล้ว (แถว '+res.row+')'); })
              .withFailureHandler(function(err){ restore('❌ อัปโหลดไม่สำเร็จ: '+(err&&err.message?err.message:err)); })
              .uploadImage({ row:row, sheetKey:CURRENT_SHEET, base64:base64, mimeType:mime, filename:'material_row'+row+'_'+(BY_ROW[row].code||'')+extFromMime_(mime) });
          }catch(e){ restore('❌ '+e.message); }
        };
        reader.onerror=function(){ restore('❌ อ่านไฟล์ไม่สำเร็จ'); };
        reader.readAsDataURL(f);
      }
      function extFromMime_(m){ if(m==='image/png')return '.png'; if(m==='image/heic'||m==='image/heif')return '.heic'; if(m==='image/webp')return '.webp'; return '.jpg'; }
      function removeImage(row,td){
