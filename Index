        google.script.run
          .withSuccessHandler(render)
          .withFailureHandler(function(err){ document.getElementById('loading').textContent='❌ โหลดข้อมูลไม่สำเร็จ: '+err.message; })
          .getMaterials(CURRENT_SHEET);
      }

      function render(data){
        MATERIALS = data || [];
        var rows = new Array(MATERIALS.length);
        for (var i=0;i<MATERIALS.length;i++){ var m=MATERIALS[i]; BY_ROW[m.row]=m; rows[i]=rowHtml(m); }
        document.getElementById('tbody').innerHTML = rows.join('');
        document.getElementById('loading').classList.add('hide');
        document.getElementById('grid').classList.remove('hide');

        buildFilterOptions();
        var s = document.getElementById('search');
        s.disabled = false;
        var ft=null;
        s.addEventListener('input', function(){ clearTimeout(ft); ft=setTimeout(applyFilters,160); });
        document.getElementById('searchClear').addEventListener('click', function(){ s.value=''; applyFilters(); s.focus(); });
        document.getElementById('filterDept').disabled=false;   wireCombo('filterDept');
        document.getElementById('filterCat').disabled=false;    wireCombo('filterCat');
        document.getElementById('filterSubCat').disabled=false; wireCombo('filterSubCat');
        document.getElementById('gridPageSize').addEventListener('change', function(){ var v=this.value; GRID_PAGE_SIZE=(v==='all')?'all':Number(v); gridPage=1; renderGridPage(); });
        document.getElementById('gridPrev').addEventListener('click', function(){ gridGoPage(-1); });
        document.getElementById('gridNext').addEventListener('click', function(){ gridGoPage(1); });

        var tbody = document.getElementById('tbody');
        tbody.addEventListener('input', onEdit);
        tbody.addEventListener('change', onChangeCommit);
        tbody.addEventListener('click', onCellClick);
        var lpTimer=null;
        tbody.addEventListener('touchstart', function(e){ touchRecently=true; var c=e.target.closest('.name-cell'); if(!c)return; clearTimeout(lpTimer); lpTimer=setTimeout(function(){ showCellTip(c); },450); }, {passive:true});
        tbody.addEventListener('touchmove', function(){ clearTimeout(lpTimer); });
        function endTouch(){ clearTimeout(lpTimer); setTimeout(function(){ touchRecently=false; },600); }
        tbody.addEventListener('touchend', endTouch); tbody.addEventListener('touchcancel', endTouch);

        var cp=document.getElementById('choicePopup');
        cp.addEventListener('click', onChoiceClick);
        cp.addEventListener('change', onChoiceChange);
        document.addEventListener('click', function(){ closeChoicePopup(); closeCellTip(); closeCombo(); });
        window.addEventListener('resize', function(){ closeChoicePopup(); closeCellTip(); closeCombo(); });
        document.querySelector('.table-wrap').addEventListener('scroll', function(){ closeChoicePopup(); closeCellTip(); });
        window.addEventListener('beforeunload', function(e){ if(Object.keys(pending).length||Object.keys(dirty).length){ e.preventDefault(); e.returnValue=''; } });

        document.getElementById('imgFile').addEventListener('change', onImgFile);

        applyViewMode();
        document.getElementById('viewToggle').addEventListener('click', function(){ document.getElementById('grid').classList.toggle('mode-collapsed'); applyViewMode(); });
        document.getElementById('refreshBtn').addEventListener('click', refreshData);
        var dcBtn=document.getElementById('deptColorBtn'); dcBtn.innerHTML=ICON.palette;
        dcBtn.addEventListener('click', openDeptColorPanel);
        document.getElementById('dcpList').addEventListener('input', onDcpColorInput);
        document.getElementById('dcpClose').addEventListener('click', closeDeptColorPanel);
        document.getElementById('dcpReset').addEventListener('click', resetDeptColors);

        setupResizers(); applyColStyle();
        document.getElementById('resizeToggle').addEventListener('click', function(){ var on=document.getElementById('grid').classList.toggle('selecting'); this.classList.toggle('active',on); if(!on) closeSizePanel(); });
        document.querySelector('#grid thead').addEventListener('click', function(e){ if(!document.getElementById('grid').classList.contains('selecting'))return; var th=e.target.closest('th'); if(!th)return; openSizePanel(th.cellIndex+1); });
        document.getElementById('spRange').addEventListener('input', function(){ setColW(spCol, Number(this.value)); });
        var pb=document.getElementById('sizePanel').querySelectorAll('.sp-presets button');
        for(var p=0;p<pb.length;p++){ pb[p].addEventListener('click', function(){ var w=Number(this.getAttribute('data-w')); document.getElementById('spRange').value=w; setColW(spCol,w); }); }
        document.getElementById('spClose').addEventListener('click', exitResizeMode);

        var tabs=document.querySelectorAll('.tab');
        for(var t=0;t<tabs.length;t++) tabs[t].addEventListener('click', function(){ switchTab(this.getAttribute('data-tab')); });
        var et=null;
        document.getElementById('erpSearch').addEventListener('input', function(){ clearTimeout(et); et=setTimeout(erpFilter,150); });
        wireCombo('erpSubFilter');
        document.getElementById('comboMenu').addEventListener('mousedown', function(e){ var it=e.target.closest('.combo-item'); if(!it) return; e.preventDefault(); e.stopPropagation(); comboPick(it.getAttribute('data-v')); });
        document.getElementById('erpPageSize').addEventListener('change', function(){ ERP_PAGE_SIZE=Number(this.value); erpPage=1; erpRenderPage(); });
        document.getElementById('erpPrev').addEventListener('click', function(){ erpGoPage(-1); });
        document.getElementById('erpNext').addEventListener('click', function(){ erpGoPage(1); });
        document.getElementById('erpPanel').addEventListener('scroll', closeCombo);
        document.getElementById('erpResults').addEventListener('click', function(e){ var b=e.target.closest('.erp-add'); if(!b)return; erpToggleSelect(b.closest('.erp-item').getAttribute('data-code'), b); });
        document.getElementById('erpTray').addEventListener('click', function(e){
          var x=e.target.closest('.erp-chip-x');
          if(x){ delete erpSelected[x.closest('.erp-chip').getAttribute('data-code')]; erpRenderTray(); erpFilter(); return; }
          if(e.target.closest('#erpSaveBtn')) erpSave();
        });
        document.getElementById('erpNoteToggle').addEventListener('click', erpToggleNote);
        document.getElementById('enCancel').addEventListener('click', erpHideNote);
        document.getElementById('enClose').addEventListener('click', erpHideNote);
        document.getElementById('enSave').addEventListener('click', erpSaveNote);
        document.getElementById('enDesc').addEventListener('input', function(){ enDescDirty=(this.value.trim()!==''); });
        wireCombo('enSub'); wireCombo('enUnit');   // Subgroup + หน่วย เป็น combobox เหมือนตัวกรอง
        document.getElementById('enTabAdd').addEventListener('click', function(){ enSwitchTab('add'); });
        document.getElementById('enTabList').addEventListener('click', function(){ enSwitchTab('list'); });
        document.getElementById('enListRefresh').addEventListener('click', enLoadList);
        document.getElementById('enUnit').addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); addEnUnit(this.value); closeCombo(); } });
        document.getElementById('enUnitChips').addEventListener('click', function(e){ var x=e.target.closest('.unit-chip-x'); if(!x) return; enUnits=enUnits.filter(function(u){ return u!==x.closest('.unit-chip').getAttribute('data-u'); }); renderEnUnitChips(); });
        document.getElementById('enList').addEventListener('click', function(e){ var d=e.target.closest('.en-note-del'); if(!d) return; var card=d.closest('.en-note-card'); enDeleteNote(Number(card.getAttribute('data-row')), card); });

        SHEET_DATA[CURRENT_SHEET]=MATERIALS;   // เก็บ cache ชีตแรก (main)
        preloadAllMat();                        // โหลด All_Mat ไว้เบื้องหลังตั้งแต่เปิดแอป
        updateStatus();
        applyFilters();                         // แบ่งหน้าครั้งแรก
      }

      // ---------- แท็บ (สลับไว ด้วย client cache) ----------
      function switchTab(which){
        if(which===CURRENT_SHEET) return;
        if(Object.keys(pending).length||Object.keys(dirty).length){ if(!confirm('ยังมีรายการที่กำลังบันทึก/ยังไม่บันทึก — สลับแท็บเลยไหม?')) return; }
        SHEET_DATA[CURRENT_SHEET]=MATERIALS;   // เก็บสถานะแท็บปัจจุบันไว้ก่อนสลับ
        CURRENT_SHEET=which;
        var tabs=document.querySelectorAll('.tab');
        for(var i=0;i<tabs.length;i++) tabs[i].classList.toggle('active', tabs[i].getAttribute('data-tab')===which);
        document.getElementById('erpPanel').classList.toggle('hide', which!=='staging');
        if(SHEET_DATA[which]) paintGrid(SHEET_DATA[which], false);   // มี cache → สลับทันที
        else { showGridLoading(); reloadGrid(null, null, false); }   // โหลดครั้งแรกของชีตนี้
        if(which==='staging'){ preloadAllMat(); erpFilter(); }       // เตรียม/แสดงผลค้นหา ERP
      }
      function showGridLoading(){
        document.getElementById('grid').classList.add('hide');
        var l=document.getElementById('loading'); l.textContent='⏳ กำลังโหลด…'; l.classList.remove('hide');
      }

      // ---------- เพิ่มจาก ERP (โหลดล่วงหน้า + ค้นหาสดฝั่ง client) ----------
      function preloadAllMat(){
        if(ALLMAT_LOADED||ALLMAT_LOADING) return;
        ALLMAT_LOADING=true;
        google.script.run
          .withSuccessHandler(function(list){
            ALLMAT_ALL=list||[]; ALLMAT_LOADED=true; ALLMAT_LOADING=false;
            buildSubFilter();
            if(CURRENT_SHEET==='staging') erpFilter();
          })
          .withFailureHandler(function(err){
            ALLMAT_LOADING=false;
            if(CURRENT_SHEET==='staging') document.getElementById('erpResults').innerHTML='<div class="erp-empty err">โหลด All_Mat ไม่สำเร็จ: '+(err&&err.message?err.message:err)+'</div>';
          })
          .getAllMatList();
      }
      function buildSubFilter(){
        var list=[]; SUBGROUP_SET={};
        for(var i=0;i<ALLMAT_ALL.length;i++){ var s=String(ALLMAT_ALL[i].subCat||'').trim(); if(s&&!SUBGROUP_SET[s]){ SUBGROUP_SET[s]=1; list.push(s); } }
        list.sort(function(a,b){ return a.localeCompare(b,'th'); });
        ALLMAT_SUBLIST=list;
        document.getElementById('erpSubFilter').placeholder='ทุก Subgroup ('+list.length+')';
      }
      // ---------- combobox ทั่วไป (ใช้กับทุกตัวกรอง: แผนก/หมวด/SubCat/Subgroup) ----------
      var COMBO_CFG = {
        filterDept:   { all:'แผนก: ทั้งหมด',    opts:function(){ return LOOKUPS.depts||[]; },    on:applyFilters },
        filterCat:    { all:'หมวด: ทั้งหมด',     opts:function(){ return LOOKUPS.mainCats||[]; }, on:applyFilters },
        filterSubCat: { all:'SubCat: ทั้งหมด',   opts:function(){ return GRID_SUBCATS; },          on:applyFilters },
        erpSubFilter: { all:'— ทุก Subgroup —',  opts:function(){ return ALLMAT_SUBLIST; },        on:erpFilter },
        enSub:        { all:'— ไม่ระบุ —',        opts:function(){ return ALLMAT_SUBLIST; },        on:function(){} },
        enUnit:       { all:'— เลือกหน่วย —',     opts:function(){ return LOOKUPS.units||[]; },     on:function(){}, pick:function(v){ addEnUnit(v); } }
      };
      function comboMenuHtml(id, filter){
        var cfg=COMBO_CFG[id], opts=cfg.opts()||[], cur=(document.getElementById(id).value||'').trim();
        filter=String(filter||'').trim().toLowerCase();
        var h='<div class="combo-item combo-all'+(cur===''?' sel':'')+'" data-v="">'+esc(cfg.all)+'</div>', n=0;
        for(var i=0;i<opts.length;i++){ var s=String(opts[i]);
          if(filter && s.toLowerCase().indexOf(filter)===-1) continue;
          h+='<div class="combo-item'+(s===cur?' sel':'')+'" data-v="'+esc(s)+'">'+esc(s)+'</div>';
          if(++n>=300) break;
        }
        if(!n && filter) h+='<div class="combo-empty">ไม่พบที่ตรง — กรองผลแบบ “มีคำนี้” ให้แทน</div>';
        return h;
      }
      function openCombo(id){
        comboActive=id;
        var inp=document.getElementById(id), menu=document.getElementById('comboMenu');
        menu.innerHTML=comboMenuHtml(id, inp.value);
        menu.classList.remove('hide');
        var r=inp.getBoundingClientRect(), w=Math.max(r.width,180);
        menu.style.width=w+'px';
        menu.style.left=Math.max(8, Math.min(r.left, window.innerWidth-w-8))+'px';
        if(r.bottom+320>window.innerHeight && r.top>340){ menu.style.top=''; menu.style.bottom=(window.innerHeight-r.top+4)+'px'; }
        else { menu.style.bottom=''; menu.style.top=(r.bottom+4)+'px'; }
      }
      function closeCombo(){ comboActive=null; document.getElementById('comboMenu').classList.add('hide'); }
      function comboPick(val){
        if(comboActive==null) return;
        var id=comboActive, cfg=COMBO_CFG[id];
        if(cfg.pick){ cfg.pick(val); openCombo(id); return; }   // multi-select: เพิ่มแล้วเปิดเมนูต่อ
        document.getElementById(id).value=val; closeCombo(); cfg.on();
      }
      function wireCombo(id){
        var inp=document.getElementById(id), t=null;
        inp.addEventListener('focus', function(){ openCombo(id); });
        inp.addEventListener('click', function(e){ e.stopPropagation(); openCombo(id); });
        inp.addEventListener('input', function(){ openCombo(id); clearTimeout(t); t=setTimeout(function(){ COMBO_CFG[id].on(); }, 160); });
        inp.addEventListener('keydown', function(e){ if(e.key==='Escape') closeCombo(); });
      }
      // เซ็ตรหัสที่มีในคลัง/สเตจิง — คำนวณจากข้อมูลที่โหลดไว้แล้ว (ไม่เรียก server)
      function erpCodeSets(){
        var wh={}, st={};
        var main=SHEET_DATA.main||(CURRENT_SHEET==='main'?MATERIALS:[])||[];
        for(var i=0;i<main.length;i++){ var c=String(main[i].code||'').trim(); if(c) wh[c]=1; }
        var stg=SHEET_DATA.staging||(CURRENT_SHEET==='staging'?MATERIALS:[])||[];
        for(var j=0;j<stg.length;j++){ var c2=String(stg[j].code||'').trim(); if(c2) st[c2]=1; }
        return {wh:wh, st:st};
      }
      function erpFilter(){
        var box=document.getElementById('erpResults'), cnt=document.getElementById('erpCount');
        if(!ALLMAT_LOADED){ box.innerHTML='<div class="erp-empty">⏳ กำลังโหลด All_Mat…</div>'; cnt.textContent=''; document.getElementById('erpPager').classList.add('hide'); return; }
        var q=(document.getElementById('erpSearch').value||'').trim().toLowerCase();
        var subRaw=(document.getElementById('erpSubFilter').value||'').trim();
        var subExact=!!SUBGROUP_SET[subRaw], subLc=subRaw.toLowerCase();   // ตรงเป๊ะ → กรอง exact, ไม่ตรง → substring
        var terms=q?q.split(/\s+/):[];
        ERP_MATCHED=[];
        for(var i=0;i<ALLMAT_ALL.length;i++){ var it=ALLMAT_ALL[i];
          if(subRaw){
            if(subExact){ if(String(it.subCat||'')!==subRaw) continue; }
            else if(String(it.subCat||'').toLowerCase().indexOf(subLc)===-1) continue;
          }
          if(terms.length){ var hay=((it.code||'')+' '+(it.name1||'')+' '+(it.subCat||'')).toLowerCase(), ok=true;
            for(var t=0;t<terms.length;t++){ if(hay.indexOf(terms[t])===-1){ ok=false; break; } } if(!ok) continue; }
          ERP_MATCHED.push(it);
        }
        erpPage=1;
        erpRenderPage();
        if(ERP_MATCHED.length===0) erpShowNote(true);   // ไม่พบใน All_Mat → เปิดฟอร์มจดอัตโนมัติ (เติมคำค้นให้)
      }
      // วาดหน้าปัจจุบัน + อัปเดตปุ่ม pagination
      function erpRenderPage(){
        var total=ERP_MATCHED.length, pages=Math.max(1, Math.ceil(total/ERP_PAGE_SIZE));
        if(erpPage>pages) erpPage=pages; if(erpPage<1) erpPage=1;
        var start=(erpPage-1)*ERP_PAGE_SIZE;
        erpRender(ERP_MATCHED.slice(start, start+ERP_PAGE_SIZE), total, erpCodeSets());
        var pager=document.getElementById('erpPager');
        if(total>ERP_PAGE_SIZE){
          pager.classList.remove('hide');
          document.getElementById('erpPageInfo').textContent='หน้า '+erpPage+'/'+pages;
          document.getElementById('erpPrev').disabled=(erpPage<=1);
          document.getElementById('erpNext').disabled=(erpPage>=pages);
        } else { pager.classList.add('hide'); }
      }
      function erpGoPage(d){ erpPage+=d; erpRenderPage(); var r=document.getElementById('erpResults'); if(r) r.scrollTop=0; }
      function erpRender(list, total, sets){
        ERP_RESULTS=list||[];
        var box=document.getElementById('erpResults'), cnt=document.getElementById('erpCount');
        if(!ERP_RESULTS.length){ box.innerHTML='<div class="erp-empty">ไม่พบรายการที่ตรงกับเงื่อนไข</div>'; cnt.textContent='0 รายการ'; return; }
        var start=(erpPage-1)*ERP_PAGE_SIZE;
        cnt.textContent = (total>ERP_PAGE_SIZE) ? ('แสดง '+(start+1)+'–'+(start+ERP_RESULTS.length)+' จาก '+total.toLocaleString()+' รายการ') : (total.toLocaleString()+' รายการ');
        var h='';
        for(var i=0;i<ERP_RESULTS.length;i++){ var it=ERP_RESULTS[i];
          var inWh=!!sets.wh[it.code], inSt=!!sets.st[it.code], exists=inWh||inSt;
          var badge=inWh?'<span class="erp-badge wh">✓ อยู่ใน '+esc(WH_NAME)+' แล้ว</span>'
                   :inSt?'<span class="erp-badge st">อยู่ใน staging แล้ว</span>':'';
          var sel=!!erpSelected[it.code];
          var btn=exists?'':'<button class="erp-add'+(sel?' on':'')+'" type="button">'+(sel?'✓ เลือกแล้ว':'+ เพิ่ม')+'</button>';
          h+='<div class="erp-item'+(inWh?' is-wh':(inSt?' is-st':''))+'" data-code="'+esc(it.code)+'">'
            +'<div class="erp-info"><div class="erp-name" title="'+esc(it.name1)+'">'+esc(it.name1)+'</div>'
            +'<div class="erp-code">'+esc(it.code)+'</div><div class="erp-sub">'+esc(it.subCat)+badge+'</div></div>'
            +btn+'</div>';
        }
        box.innerHTML=h;
      }
      function erpToggleSelect(code, btn){
        if(erpSelected[code]){ delete erpSelected[code]; if(btn){ btn.classList.remove('on'); btn.textContent='+ เพิ่ม'; } }
        else {
          var it=null; for(var i=0;i<ERP_RESULTS.length;i++){ if(ERP_RESULTS[i].code===code){ it=ERP_RESULTS[i]; break; } }
          if(!it) return; erpSelected[code]=it; if(btn){ btn.classList.add('on'); btn.textContent='✓ เลือกแล้ว'; }
        }
        erpRenderTray();
      }
      function erpRenderTray(){
        var codes=Object.keys(erpSelected), tray=document.getElementById('erpTray');
        if(!codes.length){ tray.classList.add('hide'); tray.innerHTML=''; return; }
        var chips='';
        for(var i=0;i<codes.length;i++){ var it=erpSelected[codes[i]];
          chips+='<span class="erp-chip" data-code="'+esc(it.code)+'"><span class="nm" title="'+esc(it.name1)+'">'+esc(it.name1||it.code)+'</span><span class="erp-chip-x" title="เอาออก">×</span></span>';
        }
        tray.innerHTML='<div class="erp-tray-chips">'+chips+'</div><button id="erpSaveBtn" class="erp-save" type="button">บันทึกเข้า Staging ('+codes.length+')</button>';
        tray.classList.remove('hide');
      }
      function erpSave(){
        var codes=Object.keys(erpSelected); if(!codes.length) return;
        var btn=document.getElementById('erpSaveBtn'); if(btn){ btn.disabled=true; btn.textContent='กำลังบันทึก…'; }
        google.script.run
          .withSuccessHandler(function(res){
            var added=(res&&res.added)||[], tbody=document.getElementById('tbody');
            for(var i=0;i<added.length;i++){ var m=added[i]; newRows[m.row]=true; MATERIALS.push(m); BY_ROW[m.row]=m; tbody.insertAdjacentHTML('beforeend', rowHtml(m)); }
            SHEET_DATA[CURRENT_SHEET]=MATERIALS;
            applyFilters();                       // รวมแถวใหม่เข้า pagination
            gridPage=(GRID_PAGE_SIZE==='all')?1:Math.max(1,Math.ceil(GRID_MATCHED.length/GRID_PAGE_SIZE)); renderGridPage();  // ไปหน้าสุดท้าย (ที่มีแถวใหม่)
            erpSelected={}; erpRenderTray();
            if(added.length) requestAnimationFrame(function(){ if(tbody.lastElementChild) tbody.lastElementChild.scrollIntoView({block:'center'}); });
            var msg='บันทึกเข้า staging '+added.length+' รายการ';
            if(res&&res.skipped&&res.skipped.length) msg+=' (ข้าม '+res.skipped.length+' ที่มีแล้ว)';
            showMsg('ok', msg+' — กรอกข้อมูลต่อได้เลย');
            erpFilter();   // รีเฟรชป้ายผลค้นหา (ตัวที่เพิ่งเพิ่มจะกลายเป็น "อยู่ใน staging แล้ว")
          })
          .withFailureHandler(function(err){ if(btn){ btn.disabled=false; } erpRenderTray(); showMsg('err','บันทึกไม่สำเร็จ: '+(err&&err.message?err.message:err)); })
          .addFromErpBatch(JSON.stringify(codes));
      }

      // ---------- ฟอร์มจดรายการที่ไม่มีใน ERP ----------
      function erpShowNote(prefill){
        document.getElementById('erpNotePanel').classList.remove('hide');
        document.getElementById('erpNoteToggle').classList.add('hide');
        document.getElementById('erpResults').classList.add('hide');   // ซ่อนผลค้นหา → ฟอร์มได้พื้นที่เต็ม
        enSwitchTab('add');
        if(prefill && !enDescDirty){ document.getElementById('enDesc').value=(document.getElementById('erpSearch').value||'').trim(); }
      }
      function erpHideNote(){
        document.getElementById('erpNotePanel').classList.add('hide');
        document.getElementById('erpNoteToggle').classList.remove('hide');
        document.getElementById('erpResults').classList.remove('hide');
        document.getElementById('enMsg').textContent='';
      }
      function erpToggleNote(){
        if(document.getElementById('erpNotePanel').classList.contains('hide')) erpShowNote(true); else erpHideNote();
      }
      function enSwitchTab(which){
        var add=(which!=='list');
        document.getElementById('enTabAdd').classList.toggle('active', add);
        document.getElementById('enTabList').classList.toggle('active', !add);
        document.getElementById('enFormView').classList.toggle('hide', !add);
        document.getElementById('enListView').classList.toggle('hide', add);
        if(!add) enLoadList();
      }
      // ----- หลายหน่วย (chip) -----
      function addEnUnit(u){ u=String(u||'').trim(); if(!u) return; if(enUnits.indexOf(u)===-1) enUnits.push(u); document.getElementById('enUnit').value=''; renderEnUnitChips(); }
      function renderEnUnitChips(){
        var box=document.getElementById('enUnitChips');
        box.innerHTML=enUnits.map(function(u){ return '<span class="unit-chip" data-u="'+esc(u)+'">'+esc(u)+'<span class="unit-chip-x" title="เอาออก">×</span></span>'; }).join('');
        box.classList.toggle('hide', enUnits.length===0);
      }
      function erpSaveNote(){
        var desc=document.getElementById('enDesc').value.trim(), msg=document.getElementById('enMsg');
        if(!desc){ msg.className='en-msg err'; msg.textContent='กรุณากรอกรายละเอียด/ชื่อวัสดุ'; document.getElementById('enDesc').focus(); return; }
        var typed=document.getElementById('enUnit').value.trim(); if(typed) addEnUnit(typed);   // หน่วยที่พิมพ์ค้างไว้
        var units=enUnits.slice();
        var btn=document.getElementById('enSave'); btn.disabled=true;
        msg.className='en-msg'; msg.textContent='กำลังบันทึก…';
        var payload={ query:document.getElementById('erpSearch').value, description:desc,
          subgroup:document.getElementById('enSub').value, units:units,
